<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- We add ".Base" to the name here -->
    <style name="SHIELDTheme.Base" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/shield_gold</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="android:statusBarColor">@color/shield_gold</item>
        <item name="android:navigationBarColor">@color/shield_gold</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>

    <!-- This is the actual name the Manifest looks for -->
    <style name="SHIELDTheme" parent="SHIELDTheme.Base" />

    <style name="SHIELDSplashTheme.Base" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash</item>
        <item name="android:statusBarColor">@color/shield_gold</item>
        <item name="android:navigationBarColor">@color/shield_gold</item>
    </style>

    <style name="SHIELDSplashTheme" parent="SHIELDSplashTheme.Base" />
</resources>